---====== Função de Segurança (Bloqueia salas) ======---
local function isSafeRoom()
    local latestRoom = game:GetService("ReplicatedStorage"):WaitForChild("GameData"):WaitForChild("LatestRoom").Value
    local currentRoomObj = workspace:WaitForChild("CurrentRooms"):FindFirstChild(tostring(latestRoom))
    
    -- Bloqueia Portas Específicas
    if latestRoom == 49 or latestRoom == 50 or latestRoom == 51 or latestRoom == 100 then
        return true
    end
    
    -- Bloqueia a sala do Seek (se o nome da sala tiver "Seek")
    if currentRoomObj and string.find(currentRoomObj.Name, "Seek") then
        return true
    end
    
    return false
end

