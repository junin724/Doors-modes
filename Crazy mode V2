---====== Gerenciador do Timer e Sorteio (100 segundos) ======---

local function startEntityLoop()
    while true do
        task.wait(100) 
        
        local sorteio = math.random(1, 2)
        
        if sorteio == 1 then
            print("[Gerenciador]: Sorteado Trauma! Spawnando...")
            spawnTrauma()
        else
            print("[Gerenciador]: Sorteado 200! Spawnando...")
            spawn200()
        end
    end
end

---====== Detectar abertura da primeira porta ======---

if workspace.CurrentRooms:FindFirstChild("1") then
    print("Primeira porta aberta! Iniciando loop...")
    task.spawn(startEntityLoop)
else
    local connection
    connection = workspace.CurrentRooms.ChildAdded:Connect(function(room)
        if room.Name == "1" then
            print("Primeira porta aberta! Iniciando loop...")
            connection:Disconnect()
            task.spawn(startEntityLoop)
        end
    end)
end
